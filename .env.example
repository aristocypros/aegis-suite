# OPA Policy Studio — environment for Docker Compose.
# Copy to .env and fill in values before running `docker compose up`.
#
# There are NO shared secrets to set here. User-session JWTs and the JWTs
# the backend / PEP attach to every OPA request are all signed with KMS-held
# Ed25519 keys (see "Platform signing keys" below). On a fresh deployment
# all KMS keys are minted lazily by the consuming process or by the
# opa-trust-init sidecar; rotation is admin-driven via /api/platform-keys.

# Optional. Username of the auto-generated initial admin. Defaults to "admin".
# The initial password is generated on first boot and printed to backend logs
# AND written to /data/initial_admin_password inside the backend container.
BOOTSTRAP_ADMIN_USERNAME=admin

# ─── KMS adapter (audit chain + platform signing keys) ──────────────────────
# Selects the KmsSigner provider. ALL Ed25519 signing keys (audit chain,
# backend-to-OPA auth, session JWTs, PEP-to-OPA auth) live inside this
# provider; private keys never leave it. Public-key verification is local.
#
# Supported providers:
#   vault   — HashiCorp Vault Transit (default; the laptop / on-prem path)
#   file    — DEV ONLY; refuses to start with NODE_ENV=production
#   aws     — STUB (lands in KMS-02/03)
#   gcp     — STUB
#   azure   — STUB
#   pkcs11  — STUB
KMS_PROVIDER=vault

# Audit-signing key identifier within the chosen provider. For 'vault' this
# is the Transit key name; for 'file' it is the basename of the PKCS#8 PEM
# on disk. Defaults to "audit-signing".
KMS_KEY_ID=audit-signing

# ─── Platform signing keys (replace OPA_BEARER_TOKEN and JWT_SECRET) ────────
# Per-purpose KMS keyIds. Each lives in the same KMS provider as the audit
# key. Rotation creates a new transit key suffixed with a unix-epoch
# timestamp (e.g. opa-auth-signing-1717000000); the keyId you set here is
# only the BASE name used on first boot.
#
# - opa-auth-signing       — Backend signs JWTs to OPA (aud=opa-studio-backend)
# - session-signing        — Backend signs user-session JWTs (aud=opa-policy-studio-session)
# - pep-opa-auth-signing   — PEP signs JWTs to OPA (aud=opa-studio-pep)
KMS_KEY_ID_OPA_AUTH=opa-auth-signing
KMS_KEY_ID_SESSION=session-signing
KMS_KEY_ID_PEP_OPA_AUTH=pep-opa-auth-signing

# ─── Vault provider (KMS_PROVIDER=vault) ────────────────────────────────────
# Typically left at their defaults inside the compose network. Override only
# if running the backend outside docker.
VAULT_ADDR=http://vault:8200
# Path (inside the backend container) to the file containing the Vault token
# minted by the vault-init sidecar. Delivered via the vault_secrets volume.
VAULT_TOKEN_FILE=/vault/secrets/backend_token
# Legacy alias for KMS_KEY_ID; honoured for backward compatibility.
VAULT_TRANSIT_KEY=audit-signing

# ─── File provider (KMS_PROVIDER=file, DEV ONLY) ────────────────────────────
# Directory holding per-keyId PKCS#8 PEM files (mode 0600). Defaults to
# /data/dev_kms. NEVER use in production — guarded by NODE_ENV check.
# KMS_FILE_KEY_DIR=/data/dev_kms

# ─── BYOK — Bring Your Own Key (KMS-02) ─────────────────────────────────────
# Optional. On boot, the backend loads this Ed25519 PKCS#8 PEM and imports
# it into the configured KMS provider under KMS_KEY_ID before any
# auto-generation can happen. Currently applies only to the audit-chain
# key; the per-purpose platform keys auto-mint on first boot (rotate via
# the admin UI to roll over).
#
# Supported schemes:
#   file:/absolute/path/to/key.pkcs8.pem
#   env:NAME_OF_ENV_VAR_CONTAINING_PEM
# KMS_BYOK_SOURCE=
# KMS_BYOK_REQUIRED=false

# ─── PEP caller authentication (PEP-01, multi-mode) ─────────────────────────
# The PEP no longer runs in a single global auth mode. Each pep_callers row
# declares its own auth_mode (hmac | mtls | jwt) via the admin UI; the PEP
# dispatches per request based on which credential the caller presents.
#
# Per-mode behaviour:
#   hmac — X-Studio-Sig with HMAC-SHA256(secret, ts.nonce.path.body)
#   mtls — client TLS cert; the CN must be in PEP_ALLOWED_CALLERS or in a
#          provisioned pep_callers row whose auth_mode is mtls
#   jwt  — short-lived bearer JWT verified against the platform JWKS at
#          PEP_JWKS_URL; the `sub` claim must match a jwt-mode caller_id
#          (or its jwt_subject pin)

# Dev-only escape hatch: admit credential-less requests as an anonymous
# caller. Replaces the old PEP_AUTH=none global. Refused with
# NODE_ENV=production so it cannot leak into prod-shaped runs.
PEP_DEV_ALLOW_ANON=true

# mtls support — set ALL THREE together to enable HTTPS on the PEP with
# requestCert:true (so non-mtls callers can still connect cert-less). When
# unset, the PEP listens HTTP and mtls-mode rows are not admissible.
# PEP_TLS_CERT=/etc/pep/tls/server.crt
# PEP_TLS_KEY=/etc/pep/tls/server.key
# PEP_TLS_CA=/etc/pep/tls/ca.crt

# Bootstrap CN allowlist (mtls). Lets ops admit a caller before the
# pep_callers table is populated; rows with auth_mode=mtls extend this set.
# PEP_ALLOWED_CALLERS=ci-runner.example.com,checkout.service.local

# JWT verifier: configure the platform iss + aud + jwks URL. When iss + aud
# are unset, jwt-mode caller rows are unusable (dispatcher returns
# mode_not_configured for bearer-bearing requests).
# PEP_JWKS_URL=http://backend:3001/.well-known/jwks.json
# PEP_JWT_ISSUER=https://studio.local
# PEP_JWT_AUDIENCE=pep

# Tuning knobs (defaults shown).
# PEP_HMAC_WINDOW_MS=30000     # ± skew tolerated on the timestamp
# PEP_NONCE_CACHE_MAX=50000    # max distinct nonces remembered for replay
# PEP_CALLER_TTL_MS=30000      # how often the PEP refreshes the caller set
